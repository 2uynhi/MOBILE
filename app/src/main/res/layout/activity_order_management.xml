<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".OrderManagementActivity">

    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Order report"
        android:textColor="#4CAF50"
        android:textSize="36sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- From Date Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@color/yellow"
            android:padding="8dp"
            android:text="From Date:"
            android:textColor="#33691E"
            android:textSize="18sp"
            android:textStyle="bold"
            android:minWidth="120dp" />

        <TextView
            android:id="@+id/txtFromDate"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/pink"
            android:gravity="center_vertical|end"
            android:padding="8dp"
            android:text="01/01/2026"
            android:textColor="#4A148C"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/imgFromDate"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@color/pink"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:contentDescription="Select From Date" />
    </LinearLayout>

    <!-- To Date Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@color/yellow"
            android:padding="8dp"
            android:text="To Date:"
            android:textColor="#33691E"
            android:textSize="18sp"
            android:textStyle="bold"
            android:minWidth="120dp" />

        <TextView
            android:id="@+id/txtToDate"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/pink"
            android:gravity="center_vertical|end"
            android:padding="8dp"
            android:text="31/03/2026"
            android:textColor="#4A148C"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/imgToDate"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@color/pink"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:contentDescription="Select To Date" />
    </LinearLayout>

    <!-- Filter Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/imgFilter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_search"
            android:layout_marginEnd="16dp"
            android:contentDescription="Filter" />

        <ImageView
            android:id="@+id/imgClearFilter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Clear Filter" />
    </LinearLayout>

    <ListView
        android:id="@+id/lvOrder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="#CCCCCC"
        android:dividerHeight="1dp" />

</LinearLayout>
