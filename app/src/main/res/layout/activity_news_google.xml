<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_border"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="8dp"
            android:text="@string/news_title"
            android:textColor="#A52A2A"
            android:textSize="32sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="0dp"
            android:paddingEnd="0dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:backgroundTint="#7E7EBB"
                android:contentDescription="@string/record"
                android:text="●"
                android:textColor="@color/white"
                android:textSize="22sp"
                app:cornerRadius="30dp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendGoogle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#7E7EBB"
                android:paddingVertical="12dp"
                android:text="@string/send_google"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:cornerRadius="30dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/edtNewsText"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_news_input"
            android:gravity="top|start"
            android:hint="@string/hint_news_text"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="4"
            android:padding="14dp"
            android:textColor="@color/news_text"
            android:textColorHint="@color/news_muted"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtGoogleResult"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:background="@drawable/bg_news_result"
            android:gravity="center"
            android:padding="16dp"
            android:scrollbars="vertical"
            android:text="@string/google_result_hint"
            android:textColor="@color/white"
            android:textSize="18sp" />
    </LinearLayout>
</LinearLayout>
